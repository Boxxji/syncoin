# SynCoin Configuration
# Copy this file to .env and adjust values

# Node configuration
NODE_PORT=8766
NODE_ID=syncoin-node

# Max battery usage (%) for mobile compute
MAX_BATTERY_PCT=10

# Solana (optional)
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_KEYPAIR=~/.config/solana/id.json

# Mission
MISSION=For the common good. Not for profit.
